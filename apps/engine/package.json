{
  "name": "@pavoia/engine",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc --build",
    "predev": "npm run build --workspace=@pavoia/shared",
    "dev": "concurrently --kill-others-on-fail --names shared,engine --prefix-colors cyan,magenta \"npm:dev:shared\" \"npm:dev:engine\"",
    "dev:shared": "tsc --build --watch --preserveWatchOutput ../../packages/shared",
    "dev:engine": "node --watch --experimental-strip-types src/index.ts",
    "start": "node dist/index.js",
    "pretest": "npm run build --workspace=@pavoia/shared",
    "test": "node --test --experimental-strip-types --test-reporter=spec $(find src -name '*.test.ts' -type f | sort)",
    "clean": "tsc --build --clean"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.0",
    "@pavoia/shared": "0.0.0",
    "hono": "^4.12.14"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "concurrently": "^9.2.1"
  }
}
