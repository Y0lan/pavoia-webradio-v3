        "node": ">=22.0.0"
      }
    },
    "apps/engine": {
      "name": "@pavoia/engine",
      "version": "0.0.0",
      "dependencies": {
        "@pavoia/shared": "0.0.0"
      }
    },
    "apps/web": {
      "name": "@pavoia/web",
      "version": "0.0.0",
